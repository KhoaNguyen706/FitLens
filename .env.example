# Copy to .env and fill in your password from Supabase:
# Dashboard → Project Settings → Database → Connection string

# Session pooler (recommended for local Docker + most clients, port 5432)
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.ygnfvalrxitneisdyygf
SPRING_DATASOURCE_PASSWORD=your_database_password

# Direct connection — often IPv6-only; may fail inside Docker on Windows
# SPRING_DATASOURCE_URL=jdbc:postgresql://db.ygnfvalrxitneisdyygf.supabase.co:5432/postgres?sslmode=require
# SPRING_DATASOURCE_USERNAME=postgres

# Transaction pooler — use on Heroku (port 6543)
# SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-us-east-2.pooler.supabase.com:6543/postgres?sslmode=require
# SPRING_DATASOURCE_USERNAME=postgres.ygnfvalrxitneisdyygf

# Default admin user (created once on first startup if email is not in the database)
FITLENS_ADMIN_EMAIL=admin@fitlens.local
FITLENS_ADMIN_PASSWORD=change-me-in-production
FITLENS_ADMIN_DISPLAY_NAME=Admin

# OAuth (backend verifies ID tokens from the mobile app)
# Google Cloud Console → OAuth 2.0 Client IDs (web + iOS + Android), comma-separated
GOOGLE_OAUTH_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com
# Apple Sign In — host.exp.Exponent for Expo Go; your iOS bundle ID for standalone builds
APPLE_OAUTH_CLIENT_ID=host.exp.Exponent

# OpenAI meal photo estimates. Set this on Heroku, not in Vercel.
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini
FITLENS_AI_ENABLED=true
